}
class Hyunsung : IGamism, ICodeWriter//확장성과 다중 상속 구현
{
    public void yourMajor()
    {
        Console.WriteLine("서버");
        Console.WriteLine("디자인을 잘 못해요!");
        //Console.WriteLine("yee");//유지보수성
    }
    
    public void ItMe()
    {
        Console.WriteLine("이 코드 작성자는 저에요!");
        Console.WriteLine("이 코드는 Interface예제에요!");
    }
}
public interface IGamism
{
    void yourMajor();
